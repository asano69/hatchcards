SERVER_HOST=0.0.0.0
SERVER_PORT=3000
DATA_ROOT=./cards
# Directory of pre-installed, executable post-sync hook scripts (see
# internal/hook). Defaults to "./hooks" even if unset; set explicitly here
# for clarity. Mount a host directory at the equivalent container path
# (WORKDIR is /hatchards, so "./hooks" resolves to /hatchards/hooks) if you
# want to use hooks; leave the directory empty/unmounted otherwise.
HOOKS_DIR=./hooks
FSRS_TARGET_RECALL=0.9
FSRS_MIN_INTERVAL=1.0
FSRS_MAX_INTERVAL=256.0
